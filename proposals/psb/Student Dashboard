<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Student Dashboard - The Grand Archive</title>

<!-- External colour stylesheet -->
<link rel="stylesheet" href="./style_colour.css">

<style>
    main {
        padding: 20px;
    }

    .dashboard {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
        margin-top: 20px;
    }

    .card {
        padding: 20px;
        border-radius: 10px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        text-align: center;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 20px;
    }

    th, td {
        padding: 10px;
        border: 1px solid #ccc;
    }

    .overdue {
        color: red;
        font-weight: bold;
    }
</style>
</head>

<body>

<header>
    <h1>The Grand Archive</h1>
    <nav>
        <a href="index.html">HOME</a>
        <a href="dashboard.html">STUDENT DASHBOARD</a>
        <a href="book_catalogue.html">BOOK CATALOGUE</a>
        <a href="booking_history.html">BOOK HISTORY</a>
    </nav>
</header>

<main>

<h2>Welcome, Student 👋</h2>
<p><strong>Student ID:</strong> <span id="studentID"></span></p>

<div class="dashboard">
    <div class="card">
        <h3>Books Borrowed</h3>
        <p id="borrowedCount">0</p>
    </div>

    <div class="card">
        <h3>Books Returned</h3>
        <p id="returnedCount">0</p>
    </div>

    <div class="card">
        <h3>Overdue Books</h3>
        <p id="overdueCount">0</p>
    </div>
</div>

<h3>Your Borrowed Books</h3>

<table>
    <thead>
        <tr>
            <th>Book Title</th>
            <th>Issue Date</th>
            <th>Due Date</th>
            <th>Status</th>
        </tr>
    </thead>
    <tbody id="bookTable"></tbody>
</table>

</main>

<script>
// Student ID system
let studentID = localStorage.getItem("studentID");

if (!studentID) {
    studentID = "P" + Math.floor(1000000 + Math.random() * 9000000);
    localStorage.setItem("studentID", studentID);
}

document.getElementById("studentID").innerText = studentID;

// Book data
const books = [
    {
        studentID: studentID,
        title: "The Great Gatsby",
        issueDate: "2026-03-01",
        dueDate: "2026-03-10",
        returned: true
    },
    {
        studentID: studentID,
        title: "1984",
        issueDate: "2026-03-15",
        dueDate: "2026-03-25",
        returned: false
    }
];

const table = document.getElementById("bookTable");

let borrowed = 0;
let returned = 0;
let overdue = 0;

const today = new Date();

const studentBooks = books.filter(book => book.studentID === studentID);

studentBooks.forEach(book => {
    borrowed++;

    const dueDate = new Date(book.dueDate);

    let status = "";

    if (book.returned) {
        status = "Returned";
        returned++;
    } else if (dueDate < today) {
        status = "Overdue";
        overdue++;
    } else {
        status = "Borrowed";
    }

    table.innerHTML += `
        <tr>
            <td>${book.title}</td>
            <td>${book.issueDate}</td>
            <td>${book.dueDate}</td>
            <td class="${status === 'Overdue' ? 'overdue' : ''}">
                ${status}
            </td>
        </tr>
    `;
});

document.getElementById("borrowedCount").innerText = borrowed;
document.getElementById("returnedCount").innerText = returned;
document.getElementById("overdueCount").innerText = overdue;

</script>

</body>
</html>