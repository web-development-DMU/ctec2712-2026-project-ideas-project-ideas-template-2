<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The Grand Archive - Book Catalogue</title>

<!-- External stylesheet -->
<link rel="stylesheet" href="./style_colour.css">

<style>
    body {
        font-family: Arial, sans-serif;
        margin: 0;
    }

    header {
        padding: 15px;
        text-align: center;
    }

    .container {
        width: 70%;
        margin: 30px auto;
        padding: 25px;
        border-radius: 8px;
        box-shadow: 0 0 10px rgba(0,0,0,0.1);
    }

    input {
        width: 100%;
        padding: 10px;
        margin-top: 10px;
        border-radius: 5px;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 20px;
    }

    th, td {
        padding: 10px;
        text-align: center;
    }

    button {
        padding: 8px 12px;
        border-radius: 5px;
        cursor: pointer;
        font-weight: bold;
    }

    nav {
        text-align: center;
        margin-top: 20px;
    }

    nav a {
        text-decoration: none;
        font-weight: bold;
        margin: 0 10px;
    }
</style>
</head>

<body>

<header>
    <h1>The Grand Archive</h1>
    <p>Book Catalogue</p>
</header>

<div class="container">

<h2>Available Books</h2>

<input type="text" id="searchInput" placeholder="Search for books..." onkeyup="searchBooks()">

<table id="catalogueTable">
    <tr>
        <th>Book Title</th>
        <th>Author</th>
        <th>Category</th>
        <th>Status</th>
        <th>Action</th>
    </tr>

    <tr>
        <td>Database Systems</td>
        <td>Thomas Connolly</td>
        <td>IT</td>
        <td class="available">Available</td>
        <td><button class="reserve-btn" onclick="reserveBook(this)">Reserve</button></td>
    </tr>

    <tr>
        <td>Web Development Fundamentals</td>
        <td>Jon Duckett</td>
        <td>Web</td>
        <td class="available">Available</td>
        <td><button class="reserve-btn" onclick="reserveBook(this)">Reserve</button></td>
    </tr>

    <tr>
        <td>Software Engineering</td>
        <td>Ian Sommerville</td>
        <td>IT</td>
        <td class="available">Available</td>
        <td><button class="reserve-btn" onclick="reserveBook(this)">Reserve</button></td>
    </tr>

    <tr>
        <td>Artificial Intelligence Basics</td>
        <td>Tom Taulli</td>
        <td>AI</td>
        <td class="available">Available</td>
        <td><button class="reserve-btn" onclick="reserveBook(this)">Reserve</button></td>
    </tr>

</table>

<nav>
    <a href="booking_history.html">📜 View Booking History</a>
    <a href="dashboard.html">⬅ Back to Dashboard</a>
</nav>

</div>

<script>

function searchBooks() {
    const input = document.getElementById("searchInput").value.toLowerCase();
    const rows = document.querySelectorAll("#catalogueTable tr");

    rows.forEach((row, index) => {
        if (index === 0) return;
        const text = row.textContent.toLowerCase();
        row.style.display = text.includes(input) ? "" : "none";
    });
}

function reserveBook(button) {
    const row = button.parentElement.parentElement;
    const statusCell = row.cells[3];

    statusCell.textContent = "Reserved";
    statusCell.classList.remove("available");
    statusCell.classList.add("reserved");

    button.textContent = "Reserved";
    button.disabled = true;
}

</script>

</body>
</html>